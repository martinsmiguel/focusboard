{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "identifier": "main-capability",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "fs:default",
    "dialog:default",
    "fs:allow-write-file",
    "fs:allow-read-file",
    "fs:allow-create",
    "fs:allow-remove",
    "fs:allow-write-text-file",
    "fs:allow-read-text-file",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/Downloads" },
        { "path": "$HOME/Downloads/**" },
        { "path": "$DOCUMENT" },
        { "path": "$DOCUMENT/**" },
        { "path": "$APPDATA" },
        { "path": "$APPDATA/**" }
      ]
    }
  ]
}
